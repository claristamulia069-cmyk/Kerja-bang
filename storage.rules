rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Hanya pengguna yang sudah login (anggota kepanitiaan) yang bisa
    // membaca dan mengunggah dokumen. Batas 5MB per file supaya kuota
    // gratis Firebase Storage (5GB) tahan lama untuk 17 anggota.
    match /dokumen/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
