rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isBPH() {
      return isSignedIn() && myRole() == 'bph';
    }

    // Profil anggota
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isBPH());
      allow delete: if isBPH();
    }

    // Tugas per divisi
    match /tasks/{taskId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isBPH() || resource.data.divisi == myRole());
      allow delete: if isBPH();
    }

    // Keuangan / buku kas
    match /finance/{entryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isBPH();
    }

    // Jadwal / linimasa kegiatan
    match /timeline/{eventId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isBPH() || resource.data.divisi == myRole());
      allow delete: if isBPH();
    }

    // Dokumen & proposal
    match /documents/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isBPH() || resource.data.divisi == myRole());
      allow delete: if isSignedIn() && (isBPH() || resource.data.uploadedBy == request.auth.token.email);
    }
  }
}
